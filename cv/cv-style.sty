\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{cv-style}[2026/06/28 Modern one-column CV style]

\RequirePackage{iftex}
\ifPDFTeX
  \RequirePackage{cmap}
  \RequirePackage[T1]{fontenc}
  \RequirePackage[utf8]{inputenc}
  \RequirePackage[scaled=0.95]{helvet}
\else
  \RequirePackage{fontspec}
  \defaultfontfeatures{Ligatures=TeX}
  \setsansfont{Sen.ttf}[
    Path=fonts/,
    BoldFont=Sen.ttf,
    BoldFeatures={FakeBold=2},
    ItalicFont=Sen.ttf,
    ItalicFeatures={FakeSlant=0.18},
    BoldItalicFont=Sen.ttf,
    BoldItalicFeatures={FakeBold=2,FakeSlant=0.18}
  ]
  \setmainfont{Sen.ttf}[
    Path=fonts/,
    BoldFont=Sen.ttf,
    BoldFeatures={FakeBold=2},
    ItalicFont=Sen.ttf,
    ItalicFeatures={FakeSlant=0.18},
    BoldItalicFont=Sen.ttf,
    BoldItalicFeatures={FakeBold=2,FakeSlant=0.18}
  ]
\fi
\RequirePackage[a4paper,left=1.25cm,top=1cm,right=1.25cm,bottom=1.15cm,footskip=.4cm]{geometry}
\RequirePackage{xcolor}
\RequirePackage{enumitem}
\RequirePackage{hyperref}
\RequirePackage{needspace}
\RequirePackage{ifthen}
\RequirePackage{etoolbox}
\RequirePackage{tabularx}
\RequirePackage{array}
\RequirePackage{fontawesome5}

\definecolor{cvaccent}{HTML}{0F766E}
\definecolor{cvtext}{HTML}{202124}
\definecolor{cvmuted}{HTML}{5F6368}
\definecolor{cvlight}{HTML}{DADCE0}

\newif\ifcvcompact
\newcommand{\compactcv}{%
  \cvcompacttrue
  \setlength{\parskip}{1.5pt}
  \setlist[itemize]{
    leftmargin=1.05em,
    itemsep=0pt,
    topsep=0.5pt,
    parsep=0pt,
    partopsep=0pt
  }%
}

\renewcommand{\familydefault}{\sfdefault}
\ifPDFTeX
  \ifdefined\pdfgentounicode
    \InputIfFileExists{glyphtounicode.tex}{\pdfgentounicode=1}{}
  \fi
\fi
\urlstyle{same}

\hypersetup{
  colorlinks=true,
  urlcolor=cvtext,
  linkcolor=cvtext
}

\pagestyle{empty}
\setlength{\parindent}{0pt}
\setlength{\parskip}{2.5pt}
\setlength{\emergencystretch}{2em}
\color{cvtext}
\AtBeginDocument{\raggedright}

\setlist[itemize]{
  leftmargin=1.1em,
  itemsep=1.5pt,
  topsep=1.5pt,
  parsep=0pt,
  partopsep=0pt
}
\renewcommand{\labelitemi}{\textcolor{cvaccent}{\scriptsize\textbullet}}

\newcommand{\cvfirstname}{}
\newcommand{\cvlastname}{}
\newcommand{\cvposition}{}
\newcommand{\cvemail}{}
\newcommand{\cvextra}{}

\newcommand{\name}[2]{\renewcommand{\cvfirstname}{#1}\renewcommand{\cvlastname}{#2}}
\newcommand{\position}[1]{\renewcommand{\cvposition}{#1}}
\newcommand{\email}[1]{\renewcommand{\cvemail}{#1}}
\newcommand{\extrainfo}[1]{\renewcommand{\cvextra}{#1}}
\newcommand{\cvsep}{\textcolor{cvlight}{\enspace\textbar\enspace}}
\newcommand{\positionsep}{\textcolor{cvaccent}{\enspace\textbullet\enspace}}
\newcommand{\ifcvhascontact}[2]{%
  \ifdefempty{\cvemail}
    {\ifdefempty{\cvextra}{#2}{#1}}
    {#1}%
}
\newcommand{\cvcontactline}{%
  \ifdefempty{\cvemail}
    {\ifdefempty{\cvextra}{}{\cvextra\par}}
    {%
      \ifdefempty{\cvextra}
        {\href{mailto:\cvemail}{\cvemail}\par}
        {\href{mailto:\cvemail}{\cvemail}\cvsep\cvextra\par}%
    }%
}

\newcommand{\makecvheader}[1][]{%
  {\raggedright
    \ifcvcompact
      {\fontsize{22pt}{25pt}\selectfont\bfseries \cvfirstname\ \cvlastname}\par
      {\small\color{cvmuted}\cvposition}\par
      \ifcvhascontact{\vspace{3pt}{\scriptsize\cvcontactline}}{}
    \else
      {\fontsize{25pt}{29pt}\selectfont\bfseries \cvfirstname\ \cvlastname}\par
      \vspace{1pt}
      {\normalsize\color{cvmuted}\cvposition}\par
      \ifcvhascontact{\vspace{5pt}{\footnotesize\cvcontactline}}{}
    \fi
  }
  \ifcvcompact\vspace{5pt}\else\vspace{8pt}\fi
  {\color{cvaccent}\rule{2.4cm}{0.9pt}}%
  {\color{cvlight}\rule{\dimexpr\linewidth-2.4cm\relax}{0.45pt}}\par
  \ifcvcompact\vspace{1pt}\else\vspace{3pt}\fi
}

\newcommand{\cvsection}[1]{%
  \ifcvcompact\Needspace{3\baselineskip}\else\Needspace{4\baselineskip}\fi
  \ifcvcompact\vspace{5pt}\else\vspace{8pt}\fi
  {\normalsize\bfseries\MakeUppercase{#1}}\par
  \vspace{1pt}
  {\color{cvlight}\rule{\linewidth}{0.45pt}}\par
  \ifcvcompact\vspace{0pt}\else\vspace{2pt}\fi
}

\newenvironment{cvparagraph}{\begingroup\color{cvtext}\ifcvcompact\footnotesize\else\small\fi}{\par\endgroup}
\newenvironment{cventries}{}{}
\newenvironment{cvskills}{}{}
\newenvironment{cvitems}{\begin{itemize}}{\end{itemize}}

\newcommand{\metric}[1]{%
  \textbf{#1}%
}

\newcommand{\iconlink}[3]{%
  \textcolor{cvaccent}{\makebox[1.15em][c]{\faIcon{#1}}}%
  \enspace\textbf{#2}\cvsep\href{#3}{\nolinkurl{#3}}%
}
\newcommand{\iconcontact}[4]{%
  \textcolor{cvaccent}{\makebox[1.15em][c]{\faIcon{#1}}}%
  \enspace\textbf{#2}\cvsep\href{#3}{\nolinkurl{#4}}%
}

\newcommand{\resource}[2]{\textbf{#1}\cvsep\href{#2}{\nolinkurl{#2}}}

\newcommand{\cvskill}[2]{%
  \Needspace{2\baselineskip}
  \ifcvcompact
    \noindent\begin{tabularx}{\linewidth}{@{}>{\bfseries}p{2.75cm}@{}>{\raggedright\arraybackslash}X@{}}
      #1 & {\footnotesize #2}
    \end{tabularx}\par
  \else
    \noindent\begin{tabularx}{\linewidth}{@{}>{\bfseries}p{3.15cm}@{}>{\raggedright\arraybackslash}X@{}}
      #1 & {\small #2}
    \end{tabularx}\par
    \vspace{1pt}
  \fi
}

\newcommand{\cventry}[5]{%
  \ifcvcompact\Needspace{3\baselineskip}\else\Needspace{4\baselineskip}\fi
  \ifcvcompact\vspace{1.4pt}\else\vspace{3.5pt}\fi
  {\ifcvcompact\small\else\normalsize\fi\bfseries #2%
    \ifblank{#4}{}{\hfill{\normalfont\small\color{cvmuted}#4}}%
  }\par
  \ifboolexpr{test {\ifblank{#1}} and test {\ifblank{#3}}}
    {}
    {{\footnotesize\color{cvmuted}
      \ifblank{#1}{}{\textbf{#1}}%
      \ifboolexpr{not test {\ifblank{#1}} and not test {\ifblank{#3}}}{\cvsep}{}%
      \ifblank{#3}{}{\color{cvmuted}#3}%
    }\par}%
  \ifblank{#5}{}{\vspace{1pt}{\ifcvcompact\footnotesize\else\small\fi #5}\par}%
}
