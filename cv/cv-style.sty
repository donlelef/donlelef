\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{cv-style}[2026/06/28 One-column CV style]

\RequirePackage{cmap}
\RequirePackage[T1]{fontenc}
\RequirePackage[utf8]{inputenc}
\RequirePackage[scaled=0.96]{helvet}
\RequirePackage[a4paper,left=1.25cm,top=1cm,right=1.25cm,bottom=1.15cm,footskip=.4cm]{geometry}
\RequirePackage{xcolor}
\RequirePackage{enumitem}
\RequirePackage{hyperref}
\RequirePackage{needspace}
\RequirePackage{ifthen}
\RequirePackage{etoolbox}
\RequirePackage{microtype}

\definecolor{cvaccent}{HTML}{1AEAC8}
\definecolor{cvtext}{HTML}{222222}
\definecolor{cvmuted}{HTML}{555555}
\definecolor{cvlight}{HTML}{777777}

\renewcommand{\familydefault}{\sfdefault}
\ifdefined\pdfgentounicode
  \InputIfFileExists{glyphtounicode.tex}{\pdfgentounicode=1}{}
\fi

\hypersetup{
  colorlinks=true,
  urlcolor=cvtext,
  linkcolor=cvtext
}

\pagestyle{empty}
\setlength{\parindent}{0pt}
\setlength{\parskip}{3.5pt}
\setlength{\emergencystretch}{2em}
\color{cvtext}

\setlist[itemize]{
  leftmargin=1.25em,
  itemsep=2pt,
  topsep=2pt,
  parsep=0pt,
  partopsep=0pt
}
\renewcommand{\labelitemi}{\textcolor{cvaccent}{\small\textbullet}}

\newcommand{\cvfirstname}{}
\newcommand{\cvlastname}{}
\newcommand{\cvposition}{}
\newcommand{\cvemail}{}
\newcommand{\cvextra}{}

\newcommand{\name}[2]{\renewcommand{\cvfirstname}{#1}\renewcommand{\cvlastname}{#2}}
\newcommand{\position}[1]{\renewcommand{\cvposition}{#1}}
\newcommand{\email}[1]{\renewcommand{\cvemail}{#1}}
\newcommand{\extrainfo}[1]{\renewcommand{\cvextra}{#1}}

\newcommand{\makecvheader}[1][]{%
  {\centering
    {\fontsize{24pt}{28pt}\selectfont\bfseries \cvfirstname\ \cvlastname}\par
    \vspace{2pt}
    {\large\color{cvmuted}\cvposition}\par
    \vspace{4pt}
    {\small \href{mailto:\cvemail}{\cvemail}\quad{\color{cvaccent}\textbar}\quad\cvextra}\par
  }
  \vspace{7pt}
}

\newcommand{\cvsection}[1]{%
  \Needspace{4\baselineskip}
  \vspace{7pt}
  {\large\bfseries\textcolor{cvaccent}{#1}}\par
  \vspace{-2pt}
  {\color{cvaccent}\rule{\linewidth}{0.55pt}}\par
  \vspace{1pt}
}

\newenvironment{cvparagraph}{\begingroup}{\par\endgroup}
\newenvironment{cventries}{}{}
\newenvironment{cvskills}{}{}
\newenvironment{cvitems}{\begin{itemize}}{\end{itemize}}

\newcommand{\metric}[1]{%
  \textbf{\textcolor{cvaccent}{#1}}%
}

\newcommand{\resource}[2]{\textbf{#1}: \url{#2}}

\newcommand{\cvskill}[2]{%
  \Needspace{2\baselineskip}
  \par\textbf{\textcolor{cvaccent}{#1}}\quad #2\par
}

\newcommand{\cventry}[5]{%
  \Needspace{4\baselineskip}
  \vspace{4pt}
  {\bfseries #2%
    \ifblank{#4}{}{\hfill{\normalfont\small\color{cvmuted}#4}}%
  }\par
  \ifboolexpr{test {\ifblank{#1}} and test {\ifblank{#3}}}
    {}
    {{\small
      \ifblank{#1}{}{\textcolor{cvaccent}{\textbf{#1}}}%
      \ifboolexpr{not test {\ifblank{#1}} and not test {\ifblank{#3}}}{\quad{\color{cvlight}\textbar}\quad}{}%
      \ifblank{#3}{}{\color{cvmuted}#3}%
    }\par}%
  \ifblank{#5}{}{\vspace{1pt}#5\par}%
}
